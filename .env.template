GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
JWT_SECRET=generate_with_python3_-c_"import secrets; print(secrets.token_hex(32))"
ADMIN_EMAILS=your_email@example.com
SECURE_COOKIES=false

# SMTP (for email notifications and password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_gmail@gmail.com
SITE_URL=http://localhost:8000

# ── Cost cap (system-wide kill switch — independent of per-user pages_balance) ──
# Daily and weekly USD ceilings on cumulative API spend across all users.
# Empty/0/unset = unlimited. New uploads return HTTP 503 once a cap is hit.
# Caps are evaluated against jobs.estimated_cost_usd (recorded after each job).
COST_CAP_DAILY_USD=
COST_CAP_WEEKLY_USD=
# Hard kill switch — set to "1" to reject all new uploads immediately.
# Use during incidents, deploys, or to pause spend without changing caps.
COST_CAP_KILL_SWITCH=
