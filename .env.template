GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
JWT_SECRET=generate_with_python3_-c_"import secrets; print(secrets.token_hex(32))"
ADMIN_EMAILS=your_email@example.com
SECURE_COOKIES=false

# SMTP (for email notifications and password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_gmail@gmail.com
SITE_URL=http://localhost:8000

# ── Cost cap (system-wide kill switch — independent of per-user pages_balance) ──
# Daily and weekly USD ceilings on cumulative API spend across all users.
# Empty/0/unset = unlimited. New uploads return HTTP 503 once a cap is hit.
# Caps are evaluated against jobs.estimated_cost_usd (recorded after each job).
COST_CAP_DAILY_USD=
COST_CAP_WEEKLY_USD=
# Hard kill switch — set to "1" to reject all new uploads immediately.
# Use during incidents, deploys, or to pause spend without changing caps.
COST_CAP_KILL_SWITCH=

# ── Concurrency ──
# Maximum concurrent remediation jobs. Empty/missing = 1 (historical safe value
# for Anthropic Tier-1 ITPM ~30k). Raise cautiously after observing memory and
# rate-limit headroom; ARM 12GB practical ceiling ~3.
MAX_CONCURRENT_JOBS=

# ── Per-user job caps (admins exempt) ──
# Defends queue against any single user monopolizing capacity during a surge.
# Empty/missing = use defaults. 0 / negative / invalid = unlimited.
MAX_USER_CONCURRENT_JOBS=    # default 5; max in-flight (queued+processing) per user
MAX_USER_JOBS_PER_HOUR=      # default 30; max submissions in trailing 60 minutes per user

# ── Storage retention ──
# Background cleanup deletes files older than the configured window from
# data/uploads/ and data/output/. Files referenced by queued/processing jobs
# are always preserved. Job records (in SQLite) are NOT deleted.
RETENTION_ENABLED=           # "0"/"false"/"no" disables cleanup; default enabled
RETENTION_DAYS_UPLOADS=      # default 30; age in days for data/uploads/ deletion
RETENTION_DAYS_OUTPUT=       # default 30; age in days for data/output/ deletion
RETENTION_INTERVAL_HOURS=    # default 24; how often the background loop runs
